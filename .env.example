# TinyClaw Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# NATS Configuration (Required for NATS mode)
# ============================================
NATS_URL=nats://localhost:4222
# NATS_STREAM_PREFIX=tinyclaw

# ============================================
# API Server
# ============================================
TINYCLAW_API_PORT=3777

# ============================================
# Channel Tokens (Enable the channels you need)
# ============================================

# Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# Discord
DISCORD_BOT_TOKEN=your_token_here

# WhatsApp (uses QR code pairing, no token needed)
# WhatsApp client auto-generates session

# ============================================
# AI Provider API Keys
# ============================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_key_here

# OpenAI (Codex)
OPENAI_API_KEY=your_key_here

# ============================================
# Optional Settings
# ============================================
# LOG_LEVEL=INFO
# TINYCLAW_HOME=~/.tinyclaw
